@page "/energy"
@using ClimateDashboard.Shared.Models
@rendermode InteractiveWebAssembly
@inject HttpClient Http

<PageTitle>Renewable Energy Dashboard</PageTitle>

<h1>Climate Science Data</h1>

<div class="card p-3">
  <input type="date" @bind="_pointSelectedDate"/>
  <button class="btn btn-primary" @onclick="FetchSolarPoint" disabled="@_pointIsLoading">
    @if (_pointIsLoading)
    {
      <span>Loading...</span>
    }
    else
    {
      <span>Fetch Nasa Data</span>
    }
  </button>

  @if (_pointSolarIntensity.HasValue)
  {
    <div class="mt-4">
      <h3>Results for Selected Point:</h3>
      <p><strong>Average Solar Intensity:</strong> @_pointSolarIntensity.Value.ToString("F2") kWh/m²/day</p>
    </div>
  }
  else if (_pointHasError)
  {
    <p class="text-danger mt-3">Error fetching data. Please check your connection.</p>
  }
</div>

<div class="card p-3">
  <input type="date" @bind="_regionSelectedDate"/>
  <input type="number" @bind="_regionLatMin"/>
  <input type="number" @bind="_regionLatMax"/>
  <input type="number" @bind="_regionLonMin"/>
  <input type="number" @bind="_regionLonMax"/>
  <button class="btn btn-primary" @onclick="FetchSolarRegion" disabled="@_regionIsLoading">
    @if (_regionIsLoading)
    {
      <span>Loading...</span>
    }
    else
    {
      <span>Fetch Nasa Data</span>
    }
  </button>

  @if (_solarRegion is not null)
  {
    <div class="mt-4">
      <h3>Results for Selected Region:</h3>
      @foreach (var point in _solarRegion)
      {
        <p><strong>Coordinates:</strong> Latitude: @point.Latitude.ToString("F2"),
          Longitude: @point.Longitude.ToString("F2"), Elevation: @point.Elevation.ToString("F2")</p>
        <p><strong>Solar Intensity:</strong> @point.Intensity.ToString("F2")</p>
      }
    </div>
  }
  else if (_regionHasError)
  {
    <p class="text-danger mt-3">Error fetching data. Please check your connection.</p>
  }
</div>

@code {
  private double? _pointSolarIntensity;
  private bool _pointIsLoading;
  private bool _pointHasError;
  private DateTime _pointSelectedDate = DateTime.UtcNow;

  private async Task FetchSolarPoint()
  {
    _pointIsLoading = true;
    try
    {
      var url = $"api/solar/point?latitude=42.36&longitude=-71.05&date={_pointSelectedDate}";
      _pointSolarIntensity = await Http.GetFromJsonAsync<double>(url);
    }
    catch (Exception e)
    {
      _pointHasError = true;
      Console.WriteLine($"Error: {e.Message}");
    }
    finally
    {
      _pointIsLoading = false;
    }
  }

}

@code {
  private List<SolarPoint>? _solarRegion;
  private bool _regionIsLoading;
  private bool _regionHasError;
  private DateTime _regionSelectedDate = DateTime.UtcNow;
  private double _regionLatMin;
  private double _regionLatMax;
  private double _regionLonMin;
  private double _regionLonMax;

  private async Task FetchSolarRegion()
  {
    _regionIsLoading = true;
    try
    {
      var url = $"api/solar/region?latMin={_regionLatMin}&latMax={_regionLatMax}" +
                $"&lonMin={_regionLonMin}&lonMax={_regionLonMax}" +
                $"&date={_regionSelectedDate}";
      _solarRegion = await Http.GetFromJsonAsync<List<SolarPoint>>(url);
    }
    catch (Exception e)
    {
      _regionHasError = true;
      Console.WriteLine($"Error: {e.Message}");
    }
    finally
    {
      _regionIsLoading = false;
    }
  }

}
